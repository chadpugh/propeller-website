[ {
  "id" : "010f968e-9b16-b03a-0d59-d5d913fe96d5",
  "name" : "section_controls",
  "label" : "Section Controls",
  "help_text" : "This group contains inputs which affect various parts of this section such as device visibility, spacing, color override, or other miscellaneous settings related to the entire section.",
  "required" : false,
  "locked" : false,
  "children" : [ {
    "id" : "06b3428d-0244-3077-686b-8ceb97544fcc",
    "name" : "anchor_id",
    "label" : "Anchor ID",
    "help_text" : "Adding an anchor to this section will allow you to link to this section from this or other pages. Anchor links which point to a section on the current page will scroll the user to that section while anchors links to a different page will load the page with the user already scrolled to it.",
    "inline_help_text" : "Add a unique ID to allow anchor links to this section. Only alphanumeric characters, hyphens, and underscores are permitted and this must begin with a letter. (Example: section-name) When linking to this section in an inline hyperlink, place a hashtag before the anchor ID.",
    "required" : false,
    "locked" : false,
    "allow_new_line" : false,
    "type" : "text",
    "display_width" : null
  }, {
    "id" : "ad545f18-34c5-1195-d0ae-816b9e3a0f16",
    "name" : "lazy_load_images",
    "label" : "Lazy Load Images",
    "help_text" : "Lazy loading images can help improve page load times by telling the browser to load certain images last. This feature is only supported by modern browsers and any unsupported browsers will load the images as normal.",
    "inline_help_text" : "Enable this to lazy load imagery to defer loading them initially. Depending on the section and how things are built, this input may not necessarily affect all images in this section. WARNING: This input should only be enabled for sections which appear below the fold. Not supported by all browsers.",
    "required" : false,
    "locked" : true,
    "display" : "checkbox",
    "type" : "boolean",
    "display_width" : null,
    "default" : true
  }, {
