    "name" : "spacing",
    "label" : "Spacing",
    "help_text" : "",
    "inline_help_text" : "Use these inputs to configure the top and bottom spacing of your section. This can be useful to increase or decrease the height of a section, reduce spacing between sections which share the same background color, or scale this spacing based on screen size when using certain types of backgrounds.",
